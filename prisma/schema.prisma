generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////

enum Provider {
  GOOGLE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  displayName String?
  provider  Provider @default(GOOGLE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes Vote[]

  @@index([email])
}

//////////////////////////////////////////////////
// PARTY
//////////////////////////////////////////////////

model Party {
  id        String   @id @default(cuid())
  name      String
  shortName String?
  createdAt DateTime @default(now())

  leaders Leader[]
}

//////////////////////////////////////////////////
// LOCATION (IMPORTANT FOR YOUR IDEA)
//////////////////////////////////////////////////

model State {
  id   String @id @default(cuid())
  name String

  districts District[]
  leaders   Leader[]
}

model District {
  id      String @id @default(cuid())
  name    String
  stateId String

  state State @relation(fields: [stateId], references: [id])
}

//////////////////////////////////////////////////
// LEADER (UNIFIED MODEL FOR MP + MLA)
//////////////////////////////////////////////////

enum LeaderType {
  MP
  MLA
}

model Leader {
  id   String     @id @default(cuid())
  name String
  type LeaderType

  // Relations
  partyId String?
  stateId String?

  party Party? @relation(fields: [partyId], references: [id])
  state State? @relation(fields: [stateId], references: [id])

  // Basic Info
  gender    String?
  age       Int?
  education String?

  // Constituency
  constituency String?

  // Term
  termStart DateTime?
  termEnd   DateTime?

  // Performance (normalized)
  debates    Int?   @default(0)
  questions  Int?   @default(0)
  attendance Float? // %

  // Metadata
  createdAt DateTime @default(now())

  votes Vote[]
  voteSummary LeaderVoteSummary?
  dailyVoteSummaries LeaderDailyVoteSummary[]

  @@index([stateId])
  @@index([partyId])
  @@index([type])
  @@index([stateId, type])
  @@index([partyId, type])
}

//////////////////////////////////////////////////
// REAL-TIME VOTING
//////////////////////////////////////////////////

enum VoteType {
  UPVOTE
  DOWNVOTE
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  leaderId  String
  type      VoteType
  createdAt DateTime @default(now())
  voteDate  DateTime @db.Date @default(dbgenerated("CURRENT_DATE"))

  user   User   @relation(fields: [userId], references: [id])
  leader Leader @relation(fields: [leaderId], references: [id])

  @@unique([userId, leaderId, voteDate]) // prevent duplicate voting per day
  @@index([leaderId])
  @@index([userId, createdAt])
  @@index([leaderId, createdAt])
  @@index([userId, voteDate])
  @@index([leaderId, voteDate])
}

model LeaderVoteSummary {
  leaderId   String   @id
  upvotes    Int      @default(0)
  downvotes  Int      @default(0)
  totalVotes Int      @default(0)
  popularity Float    @default(0)
  updatedAt  DateTime @updatedAt

  leader Leader @relation(fields: [leaderId], references: [id], onDelete: Cascade)

  @@index([popularity, totalVotes])
  @@index([totalVotes])
}

model LeaderDailyVoteSummary {
  leaderId   String   @db.Text
  date       DateTime @db.Date
  upvotes    Int      @default(0)
  downvotes  Int      @default(0)
  totalVotes Int      @default(0)

  leader Leader @relation(fields: [leaderId], references: [id], onDelete: Cascade)

  @@id([leaderId, date])
  @@index([date, totalVotes])
  @@index([leaderId, date])
}
