{
  "draftId": "2f60e267-d6b0-48bf-88fa-a6492fa47d21",
  "title": "JanMat Political Sentiment Platform - Light Mode",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>JanMat | Real-Time Political Sentiment Platform</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script src=\"https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js\"></script>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <style>\n        @import url('https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@800,700,500&f[]=satoshi@700,500,400&display=swap');\n\n        :root {\n            --primary: #0d9488;\n            --bg-light: #f8fafc;\n        }\n\n        body {\n            font-family: 'Satoshi', sans-serif;\n            background-color: var(--bg-light);\n            color: #1e293b;\n        }\n\n        h1, h2, h3, h4 {\n            font-family: 'Cabinet Grotesk', sans-serif;\n            letter-spacing: -0.02em;\n        }\n\n        .hero-gradient {\n            background: radial-gradient(circle at 50% 50%, rgba(13, 148, 136, 0.08) 0%, rgba(248, 250, 252, 1) 70%);\n        }\n\n        .glass-card {\n            background: #ffffff;\n            border: 1px solid #e2e8f0;\n            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05);\n        }\n\n        .status-pulse {\n            box-shadow: 0 0 0 0 rgba(20, 184, 166, 0.4);\n            animation: pulse 2s infinite;\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(20, 184, 166, 0.4); }\n            70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(20, 184, 166, 0); }\n            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(20, 184, 166, 0); }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"min-h-screen relative flex flex-col bg-slate-50\">\n        <!-- Navigation Bar -->\n        <nav class=\"fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-xl border-b border-slate-200\">\n            <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\">\n                <div class=\"flex items-center gap-2\">\n                    <div class=\"w-10 h-10 bg-teal-600 rounded-xl flex items-center justify-center shadow-lg shadow-teal-600/20\">\n                        <iconify-icon icon=\"lucide:bar-chart-3\" class=\"text-2xl text-white\"></iconify-icon>\n                    </div>\n                    <span class=\"text-2xl font-bold tracking-tighter text-slate-900\">Jan<span class=\"text-teal-600\">Mat</span></span>\n                </div>\n\n                <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-slate-600\">\n                    <a href=\"#\" id=\"nav-explore\" class=\"hover:text-teal-600 transition-colors\">Explore Leaders</a>\n                    <a href=\"#\" id=\"nav-stats\" class=\"hover:text-teal-600 transition-colors\">Insights</a>\n                    <a href=\"#\" id=\"nav-regions\" class=\"hover:text-teal-600 transition-colors\">Regions</a>\n                    <a href=\"#\" id=\"nav-about\" class=\"hover:text-teal-600 transition-colors\">How It Works</a>\n                </div>\n\n                <div class=\"flex items-center gap-4\">\n                    <button class=\"px-5 py-2.5 rounded-full bg-slate-100 border border-slate-200 hover:bg-slate-200 transition-all text-sm font-semibold text-slate-700\">Login</button>\n                    <button class=\"px-5 py-2.5 rounded-full bg-teal-600 hover:bg-teal-700 transition-all text-sm font-semibold text-white shadow-lg shadow-teal-600/20\">Get Started</button>\n                </div>\n            </div>\n        </nav>\n\n        <!-- Main Content -->\n        <main class=\"flex-1 pt-20\">\n            <!-- Hero Section -->\n            <section class=\"relative hero-gradient pt-24 pb-32 px-6 overflow-hidden\">\n                <div class=\"max-w-7xl mx-auto text-center\">\n                    <div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-teal-50 border border-teal-100 text-teal-700 text-sm font-semibold mb-8 shadow-sm\">\n                        <span class=\"w-2 h-2 rounded-full bg-teal-500 status-pulse\"></span>\n                        Live: 42,109 people voting right now\n                    </div>\n                    <h1 class=\"text-5xl md:text-7xl font-bold mb-6 max-w-4xl mx-auto leading-[1.1] tracking-tight text-slate-900\">\n                        The Real-Time Pulse of <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-teal-600 to-emerald-600\">Indian Democracy</span>\n                    </h1>\n                    <p class=\"text-slate-600 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed\">\n                        Every voice counts, every day. Track the continuous popularity of political leaders across 4,000+ constituencies. Transparent, anonymous, and data-driven.\n                    </p>\n                    <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\">\n                        <a href=\"#\" id=\"hero-vote-cta\" class=\"w-full sm:w-auto px-8 py-4 bg-teal-600 hover:bg-teal-700 text-white rounded-2xl font-bold text-lg shadow-xl shadow-teal-600/20 transition-all flex items-center justify-center gap-2\">\n                            <iconify-icon icon=\"lucide:vote\"></iconify-icon>\n                            Cast Your Vote Now\n                        </a>\n                        <a href=\"#\" id=\"hero-explore-cta\" class=\"w-full sm:w-auto px-8 py-4 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 rounded-2xl font-bold text-lg shadow-sm transition-all flex items-center justify-center gap-2\">\n                            <iconify-icon icon=\"lucide:trending-up\"></iconify-icon>\n                            Explore Trends\n                        </a>\n                    </div>\n                </div>\n                <!-- Abstract data visualization background elements -->\n                <div class=\"absolute bottom-0 left-1/2 -translate-x-1/2 w-full max-w-5xl h-64 opacity-30 pointer-events-none\">\n                    <div class=\"h-full w-full border-x border-t border-slate-200 rounded-t-[100px] flex items-end justify-center gap-2 p-4\">\n                        <div class=\"w-12 bg-teal-100 rounded-t-lg h-[40%]\"></div>\n                        <div class=\"w-12 bg-teal-200 rounded-t-lg h-[65%]\"></div>\n                        <div class=\"w-12 bg-teal-100 rounded-t-lg h-[50%]\"></div>\n                        <div class=\"w-12 bg-emerald-100 rounded-t-lg h-[85%]\"></div>\n                        <div class=\"w-12 bg-teal-50 rounded-t-lg h-[60%]\"></div>\n                        <div class=\"w-12 bg-teal-100 rounded-t-lg h-[75%]\"></div>\n                    </div>\n                </div>\n            </section>\n\n            <!-- Live Trending Leaders -->\n            <section class=\"py-24 px-6 bg-white\">\n                <div class=\"max-w-7xl mx-auto\">\n                    <div class=\"flex items-end justify-between mb-12\">\n                        <div>\n                            <h2 class=\"text-3xl font-bold text-slate-900 mb-2\">Trending Leaders</h2>\n                            <p class=\"text-slate-500 font-medium\">Top popularity rankings based on today's voting activity.</p>\n                        </div>\n                        <a href=\"#\" id=\"view-all-leaders\" class=\"text-teal-600 font-bold flex items-center gap-1 hover:gap-2 transition-all\">\n                            View All <iconify-icon icon=\"lucide:chevron-right\"></iconify-icon>\n                        </a>\n                    </div>\n\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n                        <!-- Leader Card 1 -->\n                        <div class=\"glass-card p-6 rounded-3xl hover:border-teal-400/60 hover:shadow-lg transition-all group\">\n                            <div class=\"flex items-start justify-between mb-4\">\n                                <div class=\"flex items-center gap-4\">\n                                    <div class=\"w-16 h-16 rounded-2xl bg-slate-100 overflow-hidden ring-2 ring-slate-100 group-hover:ring-teal-200 transition-all\">\n                                        <img src=\"https://api.dicebear.com/7.x/avataaars/svg?seed=Narendra\" alt=\"Leader\" class=\"w-full h-full object-cover\">\n                                    </div>\n                                    <div>\n                                        <h3 class=\"font-bold text-xl text-slate-900\">Narendra Modi</h3>\n                                        <p class=\"text-slate-500 text-sm font-medium\">Prime Minister | BJP</p>\n                                    </div>\n                                </div>\n                                <div class=\"flex flex-col items-end\">\n                                    <span class=\"text-teal-600 flex items-center gap-1 text-sm font-bold\">\n                                        <iconify-icon icon=\"lucide:trending-up\"></iconify-icon> 2.4%\n                                    </span>\n                                </div>\n                            </div>\n                            <div class=\"mb-6\">\n                                <div class=\"flex justify-between text-sm mb-2\">\n                                    <span class=\"text-slate-500 font-semibold\">Popularity Score</span>\n                                    <span class=\"font-bold text-slate-900\">72.8%</span>\n                                </div>\n                                <div class=\"w-full h-2 bg-slate-100 rounded-full overflow-hidden\">\n                                    <div class=\"h-full bg-teal-500 rounded-full\" style=\"width: 72.8%\"></div>\n                                </div>\n                            </div>\n                            <div class=\"flex items-center justify-between\">\n                                <span class=\"text-slate-400 text-xs font-semibold uppercase tracking-wider\">1.2M Votes Today</span>\n                                <button class=\"text-teal-600 text-sm font-bold bg-teal-50 px-4 py-2 rounded-xl hover:bg-teal-600 hover:text-white transition-all shadow-sm\">Vote</button>\n                            </div>\n                        </div>\n\n                        <!-- Leader Card 2 -->\n                        <div class=\"glass-card p-6 rounded-3xl hover:border-teal-400/60 hover:shadow-lg transition-all group\">\n                            <div class=\"flex items-start justify-between mb-4\">\n                                <div class=\"flex items-center gap-4\">\n                                    <div class=\"w-16 h-16 rounded-2xl bg-slate-100 overflow-hidden ring-2 ring-slate-100 group-hover:ring-teal-200 transition-all\">\n                                        <img src=\"https://api.dicebear.com/7.x/avataaars/svg?seed=Rahul\" alt=\"Leader\" class=\"w-full h-full object-cover\">\n                                    </div>\n                                    <div>\n                                        <h3 class=\"font-bold text-xl text-slate-900\">Rahul Gandhi</h3>\n                                        <p class=\"text-slate-500 text-sm font-medium\">MP, Wayanad | INC</p>\n                                    </div>\n                                </div>\n                                <div class=\"flex flex-col items-end\">\n                                    <span class=\"text-teal-600 flex items-center gap-1 text-sm font-bold\">\n                                        <iconify-icon icon=\"lucide:trending-up\"></iconify-icon> 1.8%\n                                    </span>\n                                </div>\n                            </div>\n                            <div class=\"mb-6\">\n                                <div class=\"flex justify-between text-sm mb-2\">\n                                    <span class=\"text-slate-500 font-semibold\">Popularity Score</span>\n                                    <span class=\"font-bold text-slate-900\">48.2%</span>\n                                </div>\n                                <div class=\"w-full h-2 bg-slate-100 rounded-full overflow-hidden\">\n                                    <div class=\"h-full bg-teal-500 rounded-full\" style=\"width: 48.2%\"></div>\n                                </div>\n                            </div>\n                            <div class=\"flex items-center justify-between\">\n                                <span class=\"text-slate-400 text-xs font-semibold uppercase tracking-wider\">840K Votes Today</span>\n                                <button class=\"text-teal-600 text-sm font-bold bg-teal-50 px-4 py-2 rounded-xl hover:bg-teal-600 hover:text-white transition-all shadow-sm\">Vote</button>\n                            </div>\n                        </div>\n\n                        <!-- Leader Card 3 -->\n                        <div class=\"glass-card p-6 rounded-3xl hover:border-teal-400/60 hover:shadow-lg transition-all group\">\n                            <div class=\"flex items-start justify-between mb-4\">\n                                <div class=\"flex items-center gap-4\">\n                                    <div class=\"w-16 h-16 rounded-2xl bg-slate-100 overflow-hidden ring-2 ring-slate-100 group-hover:ring-teal-200 transition-all\">\n                                        <img src=\"https://api.dicebear.com/7.x/avataaars/svg?seed=Mamata\" alt=\"Leader\" class=\"w-full h-full object-cover\">\n                                    </div>\n                                    <div>\n                                        <h3 class=\"font-bold text-xl text-slate-900\">Mamata Banerjee</h3>\n                                        <p class=\"text-slate-500 text-sm font-medium\">Chief Minister | AITC</p>\n                                    </div>\n                                </div>\n                                <div class=\"flex flex-col items-end\">\n                                    <span class=\"text-red-500 flex items-center gap-1 text-sm font-bold\">\n                                        <iconify-icon icon=\"lucide:trending-down\"></iconify-icon> 0.5%\n                                    </span>\n                                </div>\n                            </div>\n                            <div class=\"mb-6\">\n                                <div class=\"flex justify-between text-sm mb-2\">\n                                    <span class=\"text-slate-500 font-semibold\">Popularity Score</span>\n                                    <span class=\"font-bold text-slate-900\">52.4%</span>\n                                </div>\n                                <div class=\"w-full h-2 bg-slate-100 rounded-full overflow-hidden\">\n                                    <div class=\"h-full bg-teal-500 rounded-full\" style=\"width: 52.4%\"></div>\n                                </div>\n                            </div>\n                            <div class=\"flex items-center justify-between\">\n                                <span class=\"text-slate-400 text-xs font-semibold uppercase tracking-wider\">420K Votes Today</span>\n                                <button class=\"text-teal-600 text-sm font-bold bg-teal-50 px-4 py-2 rounded-xl hover:bg-teal-600 hover:text-white transition-all shadow-sm\">Vote</button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </section>\n\n            <!-- State Selector Section -->\n            <section class=\"py-24 px-6 bg-slate-50\">\n                <div class=\"max-w-7xl mx-auto text-center mb-12\">\n                    <h2 class=\"text-3xl font-bold text-slate-900 mb-4\">Check Your Region</h2>\n                    <p class=\"text-slate-600 font-medium\">Find your local MP or MLA and see how they are performing in your constituency.</p>\n                </div>\n                \n                <div class=\"max-w-3xl mx-auto flex flex-col md:flex-row gap-4\">\n                    <div class=\"flex-1 relative\">\n                        <iconify-icon icon=\"lucide:search\" class=\"absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl\"></iconify-icon>\n                        <input type=\"text\" placeholder=\"Search your constituency or district...\" class=\"w-full bg-white border border-slate-200 rounded-2xl py-4 pl-12 pr-4 focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:border-teal-500 transition-all shadow-sm\">\n                    </div>\n                    <button class=\"px-8 py-4 bg-white border border-slate-200 hover:border-teal-500 hover:text-teal-600 text-slate-700 rounded-2xl font-bold flex items-center justify-center gap-2 transition-all shadow-sm\">\n                        <iconify-icon icon=\"lucide:map-pin\"></iconify-icon>\n                        Use Location\n                    </button>\n                </div>\n\n                <div class=\"max-w-7xl mx-auto mt-12 flex flex-wrap justify-center gap-3\">\n                    <button class=\"px-6 py-2 rounded-full border border-slate-200 bg-white hover:bg-teal-50 hover:border-teal-400 hover:text-teal-700 transition-all text-sm font-bold text-slate-600 shadow-sm\">Uttar Pradesh</button>\n                    <button class=\"px-6 py-2 rounded-full border border-slate-200 bg-white hover:bg-teal-50 hover:border-teal-400 hover:text-teal-700 transition-all text-sm font-bold text-slate-600 shadow-sm\">Maharashtra</button>\n                    <button class=\"px-6 py-2 rounded-full border border-slate-200 bg-white hover:bg-teal-50 hover:border-teal-400 hover:text-teal-700 transition-all text-sm font-bold text-slate-600 shadow-sm\">West Bengal</button>\n                    <button class=\"px-6 py-2 rounded-full border border-slate-200 bg-white hover:bg-teal-50 hover:border-teal-400 hover:text-teal-700 transition-all text-sm font-bold text-slate-600 shadow-sm\">Tamil Nadu</button>\n                    <button class=\"px-6 py-2 rounded-full border border-slate-200 bg-white hover:bg-teal-50 hover:border-teal-400 hover:text-teal-700 transition-all text-sm font-bold text-slate-600 shadow-sm\">Karnataka</button>\n                    <button class=\"px-6 py-2 rounded-full border border-slate-200 bg-white hover:bg-teal-50 hover:border-teal-400 hover:text-teal-700 transition-all text-sm font-bold text-slate-600 shadow-sm\">Bihar</button>\n                    <button class=\"px-6 py-2 rounded-full border border-slate-200 bg-white hover:bg-teal-50 hover:border-teal-400 hover:text-teal-700 transition-all text-sm font-bold text-slate-600 shadow-sm\">More States...</button>\n                </div>\n            </section>\n\n            <!-- Key Stats Section -->\n            <section class=\"py-24 px-6 border-y border-slate-200 bg-white\">\n                <div class=\"max-w-7xl mx-auto\">\n                    <div class=\"grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12\">\n                        <div class=\"text-center\">\n                            <iconify-icon icon=\"lucide:users-2\" class=\"text-4xl text-teal-600 mb-4\"></iconify-icon>\n                            <h3 class=\"text-4xl font-bold mb-2 text-slate-900\">24.5M+</h3>\n                            <p class=\"text-slate-500 text-sm font-bold uppercase tracking-wider\">Total Votes Cast</p>\n                        </div>\n                        <div class=\"text-center\">\n                            <iconify-icon icon=\"lucide:activity\" class=\"text-4xl text-emerald-600 mb-4\"></iconify-icon>\n                            <h3 class=\"text-4xl font-bold mb-2 text-slate-900\">1.2M</h3>\n                            <p class=\"text-slate-500 text-sm font-bold uppercase tracking-wider\">Daily Active Users</p>\n                        </div>\n                        <div class=\"text-center\">\n                            <iconify-icon icon=\"lucide:map\" class=\"text-4xl text-teal-500 mb-4\"></iconify-icon>\n                            <h3 class=\"text-4xl font-bold mb-2 text-slate-900\">543+</h3>\n                            <p class=\"text-slate-500 text-sm font-bold uppercase tracking-wider\">Constituencies</p>\n                        </div>\n                        <div class=\"text-center\">\n                            <iconify-icon icon=\"lucide:user-check\" class=\"text-4xl text-emerald-500 mb-4\"></iconify-icon>\n                            <h3 class=\"text-4xl font-bold mb-2 text-slate-900\">4,120</h3>\n                            <p class=\"text-slate-500 text-sm font-bold uppercase tracking-wider\">Leaders Tracked</p>\n                        </div>\n                    </div>\n                </div>\n            </section>\n\n            <!-- How It Works Section -->\n            <section class=\"py-24 px-6 bg-slate-50\">\n                <div class=\"max-w-7xl mx-auto\">\n                    <div class=\"text-center mb-16\">\n                        <h2 class=\"text-3xl font-bold text-slate-900 mb-4\">How It Works</h2>\n                        <p class=\"text-slate-600 font-medium max-w-2xl mx-auto\">JanMat isn't an election, it's a daily sentiment tracker that reflects the evolving will of the people.</p>\n                    </div>\n\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8\">\n                        <!-- Step 1 -->\n                        <div class=\"relative p-6 bg-white rounded-3xl border border-slate-200 shadow-sm\">\n                            <div class=\"w-14 h-14 bg-teal-50 border border-teal-100 rounded-2xl flex items-center justify-center mb-6 shadow-sm\">\n                                <iconify-icon icon=\"lucide:search\" class=\"text-2xl text-teal-600\"></iconify-icon>\n                            </div>\n                            <h3 class=\"text-xl font-bold text-slate-900 mb-3\">1. Find Your Leader</h3>\n                            <p class=\"text-slate-500 text-sm font-medium leading-relaxed\">Browse through our extensive database of MPs and MLAs by region, party, or name.</p>\n                        </div>\n                        <!-- Step 2 -->\n                        <div class=\"relative p-6 bg-white rounded-3xl border border-slate-200 shadow-sm\">\n                            <div class=\"w-14 h-14 bg-teal-50 border border-teal-100 rounded-2xl flex items-center justify-center mb-6 shadow-sm\">\n                                <iconify-icon icon=\"lucide:fingerprint\" class=\"text-2xl text-teal-600\"></iconify-icon>\n                            </div>\n                            <h3 class=\"text-xl font-bold text-slate-900 mb-3\">2. Cast Daily Vote</h3>\n                            <p class=\"text-slate-500 text-sm font-medium leading-relaxed\">Express your approval or disapproval once every 24 hours. Your identity remains anonymous.</p>\n                        </div>\n                        <!-- Step 3 -->\n                        <div class=\"relative p-6 bg-white rounded-3xl border border-slate-200 shadow-sm\">\n                            <div class=\"w-14 h-14 bg-teal-50 border border-teal-100 rounded-2xl flex items-center justify-center mb-6 shadow-sm\">\n                                <iconify-icon icon=\"lucide:shield-check\" class=\"text-2xl text-teal-600\"></iconify-icon>\n                            </div>\n                            <h3 class=\"text-xl font-bold text-slate-900 mb-3\">3. Data Verification</h3>\n                            <p class=\"text-slate-500 text-sm font-medium leading-relaxed\">Our anti-bot algorithms ensure that every vote belongs to a real person.</p>\n                        </div>\n                        <!-- Step 4 -->\n                        <div class=\"relative p-6 bg-white rounded-3xl border border-slate-200 shadow-sm\">\n                            <div class=\"w-14 h-14 bg-teal-50 border border-teal-100 rounded-2xl flex items-center justify-center mb-6 shadow-sm\">\n                                <iconify-icon icon=\"lucide:bar-chart\" class=\"text-2xl text-teal-600\"></iconify-icon>\n                            </div>\n                            <h3 class=\"text-xl font-bold text-slate-900 mb-3\">4. View Live Trends</h3>\n                            <p class=\"text-slate-500 text-sm font-medium leading-relaxed\">Watch popularity charts evolve in real-time as public sentiment shifts based on policy.</p>\n                        </div>\n                    </div>\n                </div>\n            </section>\n\n            <!-- Bottom CTA Section -->\n            <section class=\"py-24 px-6 bg-white\">\n                <div class=\"max-w-5xl mx-auto rounded-[40px] bg-gradient-to-br from-teal-600 to-emerald-700 p-12 md:p-20 text-center relative overflow-hidden shadow-2xl shadow-teal-700/30\">\n                    <iconify-icon icon=\"lucide:quote\" class=\"absolute top-10 left-10 text-9xl text-white/10 pointer-events-none\"></iconify-icon>\n                    <h2 class=\"text-4xl md:text-5xl font-bold mb-8 text-white relative z-10\">Don't wait for five years to have your say.</h2>\n                    <p class=\"text-teal-50 text-xl mb-12 max-w-2xl mx-auto opacity-90 font-medium relative z-10\">Join millions of Indian citizens shaping the political discourse through real-time feedback and data visualization.</p>\n                    <a href=\"#\" id=\"bottom-register-cta\" class=\"inline-flex items-center gap-3 px-10 py-5 bg-white text-teal-700 rounded-2xl font-bold text-lg hover:scale-105 transition-all shadow-xl shadow-teal-900/40 relative z-10\">\n                        Create Your Anonymous Account\n                        <iconify-icon icon=\"lucide:arrow-right\"></iconify-icon>\n                    </a>\n                </div>\n            </section>\n        </main>\n\n        <!-- Footer -->\n        <footer class=\"bg-white border-t border-slate-200 py-16 px-6\">\n            <div class=\"max-w-7xl mx-auto\">\n                <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12 mb-16\">\n                    <div class=\"col-span-1 md:col-span-1\">\n                        <div class=\"flex items-center gap-2 mb-6\">\n                            <div class=\"w-8 h-8 bg-teal-600 rounded-lg flex items-center justify-center shadow-md\">\n                                <iconify-icon icon=\"lucide:bar-chart-3\" class=\"text-xl text-white\"></iconify-icon>\n                            </div>\n                            <span class=\"text-xl font-bold tracking-tighter text-slate-900\">Jan<span class=\"text-teal-600\">Mat</span></span>\n                        </div>\n                        <p class=\"text-slate-500 text-sm font-medium leading-relaxed mb-6\">\n                            India's first real-time, citizen-led political sentiment platform. We visualize public opinion to foster transparency and engagement.\n                        </p>\n                        <div class=\"flex gap-4\">\n                            <a href=\"#\" id=\"footer-twitter\" class=\"text-slate-400 hover:text-teal-600 text-xl transition-colors\"><iconify-icon icon=\"mdi:twitter\"></iconify-icon></a>\n                            <a href=\"#\" id=\"footer-linkedin\" class=\"text-slate-400 hover:text-teal-600 text-xl transition-colors\"><iconify-icon icon=\"mdi:linkedin\"></iconify-icon></a>\n                            <a href=\"#\" id=\"footer-instagram\" class=\"text-slate-400 hover:text-teal-600 text-xl transition-colors\"><iconify-icon icon=\"mdi:instagram\"></iconify-icon></a>\n                        </div>\n                    </div>\n                    \n                    <div>\n                        <h4 class=\"font-bold text-slate-900 mb-6\">Platfo